[Unit]
Description=BobHQ Connector Worker
After=network-online.target
Wants=network-online.target

[Service]
Type=notify
WorkingDirectory=/opt/bobhq/Bob.Worker
ExecStart=/opt/bobhq/Bob.Worker/Bob.Worker
Restart=always
RestartSec=10
SyslogIdentifier=bob-worker
Environment=DOTNET_ENVIRONMENT=Production

[Install]
WantedBy=multi-user.target
